{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/crear-preferencia",
      "dest": "/api/crear-preferencia.js"
    },
    {
      "src": "/webhook-mp",
      "dest": "/api/webhook-mp.js"
    },
    {
      "src": "/generar-cv",
      "dest": "/api/generar-cv.js"
    },
    {
      "src": "/guardar-cv",
      "dest": "/api/guardar-cv.js"
    },
    {
      "src": "/webhook-culqi",
      "dest": "/api/webhook-culqi.js"
    },
    {
      "src": "/descargar-cv",
      "dest": "/api/descargar-cv.js"
    },
    {
      "src": "/descargar-pdf",
      "dest": "/api/descargar-pdf.js"
    },
    {
      "src": "/extraer-cv",
      "dest": "/api/extraer-cv.js"
    },
    {
      "src": "/crear",
      "dest": "/public/index.html"
    },
    {
      "src": "/terminos",
      "dest": "/public/terminos.html"
    },
    {
      "src": "/privacidad",
      "dest": "/public/privacidad.html"
    },
    {
      "src": "/blog",
      "dest": "/public/blog-index.html"
    },
    {
      "src": "/blog/como-hacer-cv-peru-2026",
      "dest": "/public/blog-como-hacer-cv-peru-2026.html"
    },
    {
      "src": "/blog/cv-sin-experiencia-peru",
      "dest": "/public/blog-cv-sin-experiencia-peru.html"
    },
    {
      "src": "/blog/como-pasar-filtros-ats",
      "dest": "/public/blog-como-pasar-filtros-ats.html"
    },
    {
      "src": "/",
      "dest": "/public/landing.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}