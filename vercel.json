{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/generar-cv",
      "dest": "/api/generar-cv.js"
    },
    {
      "src": "/descargar-pdf",
      "dest": "/api/descargar-pdf.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}